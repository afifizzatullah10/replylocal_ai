# ================================================================
# ReplyLocal — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local`.
# ================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Toggle mock data so the app runs end-to-end without Google API access.
# Set to "true" while waiting on Google Business Profile API approval.
NEXT_PUBLIC_MOCK_MODE=true

# ---- Supabase ----
# Create a project at https://supabase.com, then grab these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Only used in server-side routes that bypass RLS (webhooks, cron).
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google Business Profile OAuth ----
# From Google Cloud Console → APIs & Services → Credentials.
# Required scope: https://www.googleapis.com/auth/business.manage
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ---- Anthropic (Claude) ----
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# Models (tune based on cost/quality tradeoff)
ANTHROPIC_MODEL_DRAFT=claude-haiku-4-5
ANTHROPIC_MODEL_NEGATIVE=claude-sonnet-4-5

# ---- Twilio ----
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Waitlist ----
# POST /api/waitlist — signups are logged only (see server / Vercel function logs).

# ---- Cron security ----
# Set a long random string. Vercel Cron sends this in the Authorization header.
CRON_SECRET=

# ---- Encryption ----
# 32-byte base64 key used to encrypt Google refresh tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
